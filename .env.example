# ───────────────────────────────────────────────────────────────
# Copy to `.env` and fill in. Nothing here ships to git.
# ───────────────────────────────────────────────────────────────

# Postgres — matches docker-compose.yml defaults for local dev.
DATABASE_URL=postgres://mlie:mlie@localhost:5433/mlie

# ── Google Calendar (read) ──────────────────────────────────────
# From Google Cloud Console → OAuth 2.0 Client (Web application).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
# Refresh token obtained once via the OAuth consent flow.
GOOGLE_REFRESH_TOKEN=
# The two source calendars (find the IDs in Google Calendar settings).
MLIG_CALENDAR_ID=
MLIE_CALENDAR_ID=

# ── QuickBooks Online ───────────────────────────────────────────
# From the Intuit developer portal. Start with the SANDBOX app keys.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
# 'sandbox' or 'production'. Keep sandbox until cutover.
QBO_ENVIRONMENT=sandbox
# Obtained via the OAuth flow; realmId is the company id.
QBO_REALM_ID=
QBO_REFRESH_TOKEN=

# ── Scheduler ───────────────────────────────────────────────────
# Shared secret the cron route checks before running a cycle.
CRON_SECRET=
